# ============================================
# 淘籍籍 环境变量配置 (.env)
# 复制此文件为 .env 并修改其中的值
# ============================================

# JWT 密钥（务必修改！不要用默认值）
JWT_SECRET=change-me-to-a-random-string

# MySQL 配置
MYSQL_PASSWORD=1234

# Redis 配置 (默认无需密码)
REDIS_PASSWORD=

# CORS 允许的前端域名（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://1550493847-dotcom.github.io

# ===== 支付宝沙箱支付 =====
# 商户私钥（RSA2），填入你的私钥（一行，不要换行）
ALIPAY_MERCHANT_PRIVATE_KEY=你的RSA2私钥
